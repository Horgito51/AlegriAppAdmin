# Variables necesarias para ejecutar el servidor de webhook de Telegram
SUPABASE_URL=https://<tu-proyecto>.supabase.co/rest/v1
SUPABASE_SERVICE_ROLE_KEY=<tu-service-role-key>
TELEGRAM_BOT_TOKEN=<token-del-bot>
TELEGRAM_BOT_USERNAME=<nombre_del_bot_sin_arroba>
TELEGRAM_SECRET_KEY=<clave-secreta-para-firmas>
PORT=3000
